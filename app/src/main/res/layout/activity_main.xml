<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Шифрующий TCP-прокси для Telegram"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Локальный порт -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local Port (127.0.0.1 only)"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etLocalPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="1080"
            android:maxLength="5"
            android:layout_marginBottom="20dp" />

        <!-- Удалённый сервер -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remote IP or name"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etRemoteHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="123.45.67.89 или your-vps.com"
            android:layout_marginBottom="20dp" />

        <!-- Удалённый порт -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remote Port"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etRemotePort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="9999"
            android:maxLength="5"
            android:layout_marginBottom="20dp" />

        <!-- Фраза для шифрования -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password for XOR"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPassphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:hint="минимум 8 символов"
            android:layout_marginBottom="32dp" />

        <!-- Кнопки Запустить / Остановить -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="START"
                android:textSize="16sp"
                android:padding="14dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="STOP"
                android:textSize="16sp"
                android:padding="14dp"
                android:layout_marginStart="8dp"
                android:enabled="false" />

        </LinearLayout>

        <!-- Статус -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Прокси остановлен"
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="@android:color/holo_red_dark"
            android:layout_marginBottom="32dp" />

        <!-- Быстрая настройка Telegram -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Быстрая настройка Telegram"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvTelegramLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Открыть в Telegram →"
            android:textSize="18sp"
            android:textColor="@android:color/holo_blue_dark"
            android:gravity="center"
            android:padding="12dp"
            android:background="@android:color/darker_gray"
            android:clickable="true"
            android:focusable="true"
            android:backgroundTint="#E3F2FD" />

        <!-- Подсказка -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="После запуска нажми выше → Telegram сам настроит SOCKS5 на 127.0.0.1:1080"
            android:textSize="13sp"
            android:gravity="center"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>